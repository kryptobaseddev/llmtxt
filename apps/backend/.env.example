# ─── Server Configuration ────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: SQLite file
DATABASE_URL=./data.db
# Production (Railway Postgres addon):
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ─── Cache Configuration ─────────────────────────────────────────────────────
CACHE_MAX_SIZE=1000
CACHE_TTL=86400000

# ─── Observability — Self-Hosted on Railway ───────────────────────────────────
#
# All observability services run inside the Railway project's private network.
# No external SaaS (Grafana Cloud, Sentry cloud, Datadog) is used.
#
# In the Railway dashboard, set these env vars for the backend service using
# Railway Reference Variables that resolve to internal private-network domains:

# OTel Collector — receives OTLP from this service, fans out to Tempo/Prometheus/Loki
# OTEL_EXPORTER_OTLP_ENDPOINT=http://${{OtelCollector.RAILWAY_PRIVATE_DOMAIN}}:4318

# Loki — structured log storage (queried by Grafana)
# LOKI_HOST=${{Loki.RAILWAY_PRIVATE_DOMAIN}}
# LOKI_USER=       (not required for self-hosted — Loki runs auth_enabled: false)
# LOKI_PASSWORD=   (not required for self-hosted)

# GlitchTip — OSS Sentry-compatible error tracking (self-hosted)
# Paste the DSN generated in the GlitchTip admin after creating your project:
# SENTRY_DSN=${{GlitchTip.GLITCHTIP_PUBLIC_DSN}}

# Optional: override OTel auth header (not needed for self-hosted collector)
# OTEL_AUTH_HEADER=

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Redis (optional — enables pub/sub for CRDT and presence) ────────────────
# REDIS_URL=${{Redis.REDIS_URL}}

# ─── Lease Enforcement (T704) ─────────────────────────────────────────────────
# STRICT_LEASES=1
#
# When set to "1", converts section leases from advisory-only to server-enforced.
#
# Effect:
#   POST /documents/:slug/sections/:sid/crdt-update checks section_leases for
#   any active (non-expired) lease on the target section. If a different agent
#   holds the lease, the write is blocked with HTTP 409 Conflict:
#     { "error": "lease_held", "holder": "<agentId>", "expiresAt": "<iso>" }
#
# If-Match header (optional, for lease-holders):
#   Include "If-Match: <leaseId>" to assert exclusive ownership. The server
#   validates the token matches the stored lease. Mismatch returns 409:
#     { "error": "lease_token_mismatch", "holder": "...", "expiresAt": "..." }
#
# Backwards compatibility:
#   Without STRICT_LEASES=1, all behaviour is unchanged (leases remain advisory).
#   Existing clients that do not acquire leases will continue to write normally.
#
# Requires: PostgreSQL backend (section_leases table is PG-only).
#           Set DATABASE_URL_PG and ensure migrations have run.
#
# Recommended for production multi-agent deployments where concurrent section
# edits from non-cooperating agents must be prevented at the server level.
# STRICT_LEASES=1
