  "operations": [
    {
      "id": "op-enforceContentSize",
      "name": "enforceContentSize",
      "what": "Enforce the maximum document content size.  Reads `content` from the request body and rejects with 413 if the UTF-8 byte length exceeds CONTENT_LIMITS.maxDocumentSize. Safe to call on any route that accepts a `content` body field.",
      "tags": [
        "read"
      ],
      "inputs": []
    },
    {
      "id": "op-enforcePatchSize",
      "name": "enforcePatchSize",
      "what": "Enforce the maximum patch content size.  Reads `patchText` from the request body and rejects with 413 if its byte length exceeds CONTENT_LIMITS.maxPatchSize.",
      "tags": [
        "read"
      ],
      "inputs": []
    },
    {
      "id": "op-enforceDocumentLimit",
      "name": "enforceDocumentLimit",
      "what": "Enforce the maximum number of documents per authenticated user.  Counts documents owned by request.user.id and rejects with 429 if at or above CONTENT_LIMITS.maxDocumentsPerUser. Skips the check for unauthenticated requests (anonymous creation still allowed up to the rate limit; ownership won't accumulate).",
      "tags": [],
      "inputs": []
    },
    {
      "id": "op-validateHashChain",
      "name": "validateHashChain",
      "what": "Validate the hash chain for the last `limit` rows of a document's event log.  Walks the rows in ascending seq order and recomputes each prev_hash, comparing against the stored value. Returns the first broken seq if any.",
      "tags": [],
      "inputs": [
        {
          "name": "db",
          "type": {
            "canonical": "any",
            "original": "unknown"
          },
          "required": true,
          "description": "Drizzle client (outside any transaction)."
        },
        {
          "name": "slug",
          "type": {
            "canonical": "any",
            "original": "unknown"
          },
          "required": true,
          "description": "Document slug (= document_id FK)."
        },
        {
          "name": "limit",
          "type": {
            "canonical": "any",
            "original": "unknown"
          },
          "required": true,
          "description": "Number of recent rows to validate (default 100)."
        }
      ]
    },
    {
      "id": "op-generateApiKey",
      "name": "generateApiKey",
      "what": "Generate a new API key.",
      "tags": [],
      "inputs": [],
      "outputs": {
        "type": {
          "canonical": "object",
          "original": "An object containing:   - `rawKey`: the full key string (return to user ONCE, never store)   - `keyHash`: SHA-256 hex digest to persist in the database   - `keyPrefix`: display prefix for the database (first 8 random chars)"
        },
        "description": "An object containing:   - `rawKey`: the full key string (return to user ONCE, never store)   - `keyHash`: SHA-256 hex digest to persist in the database   - `keyPrefix`: display prefix for the database (first 8 random chars)"
      }
    },
    {
      "id": "op-createEmbeddingProvider",
      "name": "createEmbeddingProvider",
      "what": "Select the best available embedding provider.  - If `OPENAI_API_KEY` is set → `OpenAIEmbeddingProvider` (`text-embedding-3-small`). - Otherwise → `LocalEmbeddingProvider` (TF-IDF, 256-dimensional, no external API).",
      "tags": [],
