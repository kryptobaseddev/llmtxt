{
  "name": "@llmtxt/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts",
    "db:generate:pg": "drizzle-kit generate --config=drizzle-pg.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config=drizzle-pg.config.ts",
    "db:push:pg": "drizzle-kit push --config=drizzle-pg.config.ts",
    "forge:check": "forge-ts check",
    "forge:test": "forge-ts test",
    "forge:build": "forge-ts build",
    "forge:doctor": "forge-ts doctor",
    "prepublishOnly": "forge-ts prepublish",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.1.0",
    "dompurify": "^3.3.3",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "drizzle-zod": "0.7.0",
    "fastify": "^5.2.2",
    "gpt-tokenizer": "^3.4.0",
    "jsdom": "^29.0.2",
    "llmtxt": "workspace:*",
    "pg": "^8.20.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "eslint": "^8.57.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "drizzle-zod": {
      "drizzle-orm": "$drizzle-orm"
    }
  }
}
