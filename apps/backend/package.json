{
  "name": "@llmtxt/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --import ./dist/instrumentation.js dist/index.js",
    "start:migrate": "node --import tsx/esm scripts/run-migrations.ts && node --import ./dist/instrumentation.js dist/index.js",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts",
    "db:generate:pg": "drizzle-kit generate --config=drizzle-pg.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config=drizzle-pg.config.ts",
    "db:push:pg": "drizzle-kit push --config=drizzle-pg.config.ts",
    "forge:check": "pnpm -w exec forge-ts check",
    "forge:test": "pnpm -w exec forge-ts test",
    "forge:build": "pnpm -w exec forge-ts build",
    "forge:doctor": "pnpm -w exec forge-ts doctor",
    "openapi:gen": "pnpm -w exec forge-ts build --skip-gen && node scripts/postman-gen.mjs",
    "openapi:validate": "node scripts/validate-openapi.mjs openapi.json",
    "openapi:ts-client": "openapi-typescript openapi.json -o /tmp/llmtxt-api-types.ts && echo 'TS client codegen: OK'",
    "prepublishOnly": "pnpm -w exec forge-ts prepublish",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@sentry/node": "^10.48.0",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.1.0",
    "dompurify": "^3.3.3",
    "drizzle-orm": "1.0.0-beta.21",
    "fastify": "^5.2.2",
    "fastify-plugin": "^5.1.0",
    "gpt-tokenizer": "^3.4.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.2",
    "llmtxt": "workspace:*",
    "nanoid": "^5.1.9",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@forge-ts/api": "0.24.0",
    "@forge-ts/core": "0.24.0",
    "@sentry/cli": "^3.3.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.13.10",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "1.0.0-beta.21",
    "eslint": "^8.57.0",
    "openapi-schema-validator": "^12.1.3",
    "openapi-to-postmanv2": "6.0.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {}
}
