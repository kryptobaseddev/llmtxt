{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for llmtxt-api metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "LLMtxt SLO/SLI dashboard — latency percentiles, error rates, and error budget burn rates per endpoint class.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": [],
      "title": "SLO Definition",
      "tooltip": "ops/SLO.md",
      "type": "link",
      "url": "https://github.com/kryptobaseddev/llmtxt/blob/main/ops/SLO.md"
    },
    {
      "icon": "external link",
      "tags": [],
      "title": "Runbook",
      "tooltip": "ops/RUNBOOK.md",
      "type": "link",
      "url": "https://github.com/kryptobaseddev/llmtxt/blob/main/ops/RUNBOOK.md"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "SLO Status — sections endpoint (P0)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "s",
          "max": 0.5,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "sections p50 (SLO: <50ms)",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_request_duration_seconds:p50_5m",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s",
          "max": 0.5,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "sections p95 (SLO: <200ms)",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_request_duration_seconds:p95_5m",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "sections p99 (SLO: <500ms)",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_request_duration_seconds:p99_5m",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit",
          "max": 0.1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "sections error rate (SLO: <1%)",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_error_rate:rate5m",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Latency Trends — all endpoint classes",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 10,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "p95 latency by endpoint class (SLO threshold lines)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_request_duration_seconds:p95_5m",
          "legendFormat": "sections",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_documents_request_duration_seconds:p95_5m",
          "legendFormat": "documents",
          "refId": "B"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_writes_request_duration_seconds:p95_5m",
          "legendFormat": "writes",
          "refId": "C"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_auth_request_duration_seconds:p95_5m",
          "legendFormat": "auth",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 11,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Error rate by endpoint class",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_sections_error_rate:rate5m",
          "legendFormat": "sections",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_documents_error_rate:rate5m",
          "legendFormat": "documents",
          "refId": "B"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_writes_error_rate:rate5m",
          "legendFormat": "writes",
          "refId": "C"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_auth_error_rate:rate5m",
          "legendFormat": "auth",
          "refId": "D"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Error Budget",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 17 },
      "id": 20,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Error budget remaining (30d rolling)",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "1 - (sum(increase(http_requests_total{job=\"llmtxt-api\",route!~\"/api/health|/api/ready|/api/metrics\",status_code=~\"5..\"}[30d])) / sum(increase(http_requests_total{job=\"llmtxt-api\",route!~\"/api/health|/api/ready|/api/metrics\"}[30d]))) / 0.005",
          "legendFormat": "budget remaining",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 36 },
              { "color": "red", "value": 72 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 17 },
      "id": 21,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Burn rate (warning=36x, critical=72x)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_all_error_rate:rate1h / 0.005",
          "legendFormat": "burn rate (1h window)",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "job:llmtxt_all_error_rate:rate5m / 0.005",
          "legendFormat": "burn rate (5m window)",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["slo", "sli", "llmtxt", "observability"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLMtxt SLO Dashboard",
  "uid": "llmtxt-slo-v1",
  "version": 1
}
