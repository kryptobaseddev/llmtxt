{
  "name": "llmtxt-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @llmtxt/backend dev",
    "start": "pnpm --filter @llmtxt/backend start",
    "db:generate": "pnpm --filter @llmtxt/backend db:generate",
    "db:migrate": "pnpm --filter @llmtxt/backend db:migrate",
    "db:push": "pnpm --filter @llmtxt/backend db:push",
    "db:studio": "pnpm --filter @llmtxt/backend db:studio",
    "test": "pnpm --filter @llmtxt/backend test",
    "typecheck": "pnpm --filter @llmtxt/backend build"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node"
    ]
  },
  "devDependencies": {
    "@forge-ts/cli": "^0.21.1"
  }
}
