{
  "name": "llmtxt-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @llmtxt/web dev",
    "start": "pnpm --filter @llmtxt/web start",
    "db:generate": "pnpm --filter @llmtxt/web db:generate",
    "db:migrate": "pnpm --filter @llmtxt/web db:migrate",
    "db:push": "pnpm --filter @llmtxt/web db:push",
    "db:studio": "pnpm --filter @llmtxt/web db:studio"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
