{
  "name": "llmtxt",
  "version": "2026.4.12",
  "description": "Primitives and SDK for LLM agent content workflows: compression, patching, progressive disclosure, signed URLs, collaborative document lifecycle, and retrieval planning",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llmtxt": "./dist/cli/llmtxt.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./local": {
      "types": "./dist/local/index.d.ts",
      "import": "./dist/local/index.js"
    },
    "./remote": {
      "types": "./dist/remote/index.d.ts",
      "import": "./dist/remote/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./disclosure": {
      "types": "./dist/disclosure.d.ts",
      "import": "./dist/disclosure.js"
    },
    "./similarity": {
      "types": "./dist/similarity.d.ts",
      "import": "./dist/similarity.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "import": "./dist/graph.js"
    },
    "./crdt": {
      "types": "./dist/crdt.d.ts",
      "import": "./dist/crdt.js"
    },
    "./crdt-primitives": {
      "types": "./dist/crdt-primitives.d.ts",
      "import": "./dist/crdt-primitives.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings.d.ts",
      "import": "./dist/embeddings.js"
    },
    "./pg": {
      "types": "./dist/pg/index.d.ts",
      "import": "./dist/pg/index.js"
    },
    "./export-backend": {
      "types": "./dist/export/backend-export.d.ts",
      "import": "./dist/export/backend-export.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./blob": {
      "types": "./dist/blob/index.d.ts",
      "import": "./dist/blob/index.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/local/migrations dist/local/migrations",
    "build:wasm": "bash -lc \"cd ../../crates/llmtxt-core && wasm-pack build --target nodejs --out-dir ../../packages/llmtxt/wasm --features crdt && rm -f ../../packages/llmtxt/wasm/.gitignore\"",
    "build:all": "pnpm run build:wasm && pnpm run build",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts src/sdk/sdk.contract.test.ts src/crdt/crdt.contract.test.ts src/similarity/similarity.contract.test.ts src/blob/__tests__/contract.test.ts",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run typecheck && pnpm exec forge-ts check && pnpm exec versionguard validate",
    "prepublishOnly": "node -e \"if (!process.env.PUBLISH_ONLY_IN_CI) { console.error('\\nERROR: Direct npm publish is not allowed.\\n\\nPublishing llmtxt must go through GitHub Actions to ensure:\\n  - OIDC provenance attestation (--provenance flag)\\n  - CHANGELOG validation gate\\n  - Migration safety gates\\n  - Full test suite\\n\\nTo release: push a core-v<VERSION> tag to trigger the CI workflow.\\n  git tag core-v<VERSION>\\n  git push origin core-v<VERSION>\\n'); process.exit(1); }\""
  },
  "keywords": [
    "llm",
    "agent",
    "compression",
    "content",
    "patch",
    "signed-urls",
    "versioning",
    "collaborative-docs",
    "sdk",
    "wasm"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "loro-crdt": "^1.11.0",
    "nanoid": "^5.1.9",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@cleocode/lafs": ">=2026.3",
    "@vlcn.io/crsqlite": ">=0.16.3",
    "better-sqlite3": ">=11.0.0",
    "drizzle-orm": ">=1.0.0-beta.21",
    "onnxruntime-node": ">=1.18.0",
    "postgres": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "@cleocode/lafs": {
      "optional": true
    },
    "@vlcn.io/crsqlite": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cleocode/lafs": "^2026.3.74",
    "@codluv/versionguard": "^0.9.0",
    "@forge-ts/api": "^0.21.1",
    "@forge-ts/cli": "^0.21.1",
    "@forge-ts/core": "^0.21.1",
    "@forge-ts/doctest": "^0.21.1",
    "@forge-ts/enforcer": "^0.21.1",
    "@forge-ts/gen": "^0.21.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "drizzle-kit": "1.0.0-beta.21",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/llmtxt.git",
    "directory": "packages/llmtxt"
  },
  "homepage": "https://github.com/kryptobaseddev/llmtxt/tree/main/packages/llmtxt",
  "bugs": {
    "url": "https://github.com/kryptobaseddev/llmtxt/issues"
  }
}
