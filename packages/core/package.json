{
  "name": "@codluv/llmtxt",
  "version": "2026.3.1",
  "description": "Core primitives for llmtxt: compression, validation, patching, progressive disclosure, signed URLs, and attachment helpers for LLM agent content workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash -lc \"cd ../../crates/llmtxt-core && wasm-pack build --target nodejs --out-dir ../../packages/core/wasm && rm -f ../../packages/core/wasm/.gitignore\"",
    "build:all": "pnpm run build:wasm && pnpm run build",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run typecheck && pnpm exec forge-ts check && pnpm exec versionguard validate"
  },
  "keywords": [
    "llm",
    "agent",
    "compression",
    "content",
    "patch",
    "signed-urls",
    "versioning",
    "wasm"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.25.3"
  },
  "peerDependencies": {
    "@cleocode/lafs": ">=2026.3"
  },
  "peerDependenciesMeta": {
    "@cleocode/lafs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cleocode/lafs": "^2026.3.74",
    "@codluv/versionguard": "^0.9.0",
    "@forge-ts/api": "^0.21.1",
    "@forge-ts/cli": "^0.21.1",
    "@forge-ts/doctest": "^0.21.1",
    "@forge-ts/enforcer": "^0.21.1",
    "@forge-ts/gen": "^0.21.1",
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3",
    "@forge-ts/core": "^0.21.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/llmtxt.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/kryptobaseddev/llmtxt/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/kryptobaseddev/llmtxt/issues"
  }
}
