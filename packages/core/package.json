{
  "name": "@codluv/llmtxt",
  "version": "0.4.0",
  "description": "Core primitives for llmtxt: compression, validation, progressive disclosure, signed URLs, similarity, and caching for LLM agent content workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "llm",
    "agent",
    "compression",
    "content",
    "progressive-disclosure",
    "signed-urls",
    "similarity",
    "fingerprint",
    "org-scoped"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.25.3"
  },
  "peerDependencies": {
    "@cleocode/lafs": ">=2026.3"
  },
  "peerDependenciesMeta": {
    "@cleocode/lafs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cleocode/lafs": "^2026.3.74",
    "@codluv/versionguard": "^0.5.0",
    "@forge-ts/api": "^0.21.1",
    "@forge-ts/cli": "^0.21.1",
    "@forge-ts/doctest": "^0.21.1",
    "@forge-ts/enforcer": "^0.21.1",
    "@forge-ts/gen": "^0.21.1",
    "@types/node": "^22.19.15",
    "forge-ts": "^0.0.2",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/llmtxt.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/kryptobaseddev/llmtxt/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/kryptobaseddev/llmtxt/issues"
  }
}
